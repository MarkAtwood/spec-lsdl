p1 = [6,8]
p2 = C([4,8] [2,9])
p3 = C([1,10] [2,10])
p4 = [3,10]
close: false
width: 1
anchors: attach=[6,8]
@end

# swash.top - Top swash
@elem swash.top
zone: ascender
path: p1 p2 p3 p4
p1 = [6,1]
p2 = C([8,1] [10,0])
p3 = C([11,0] [10,1])
p4 = [9,1]
close: false
width: 1
anchors: attach=[6,1]
@end

# -----------------------------------------------------------------------------
# flag - Small horizontal at top of stem (as in 1, soft sign)
# -----------------------------------------------------------------------------
@elem flag
zone: x-height
path: p1 p2 p3
p1 = [4,4]
p2 = [6,4]
p3 = [6,5]
close: false
width: 1
anchors: attach=[6,4]
@end

# flag.cap - Capital-height flag
@elem flag.cap
zone: cap
path: p1 p2 p3
p1 = [4,0]
p2 = [6,0]
p3 = [6,1]
close: false
width: 1
anchors: attach=[6,0]
@end

# flag.l - Left flag
@elem flag.l
zone: x-height
path: p1 p2 p3
p1 = [8,4]
p2 = [6,4]
p3 = [6,5]
close: false
width: 1
anchors: attach=[6,4]
@end

# -----------------------------------------------------------------------------
# tittle - Dot above (as in i, j)
# -----------------------------------------------------------------------------
@elem tittle
zone: x-height
path: p1 p2 p3 p4
p1 = [6,2]
p2 = C([7,2] [7,3])
p3 = C([7,4] [6,4])
p4 = C([5,4] [5,3])
close: true
width: 1
anchors: attach=[6,3] base=[6,4]
  mark-above=[6,1]
@end

# tittle.square - Square tittle
@elem tittle.square
zone: x-height
path: p1 p2 p3 p4
p1 = [5,2]
p2 = [7,2]
p3 = [7,4]
p4 = [5,4]
close: true
width: 1
anchors: attach=[6,3] base=[6,4]
@end

# =============================================================================
# SPECIAL (3 base elements)
# =============================================================================

# -----------------------------------------------------------------------------
# dot - Period/point (standalone dot)
# -----------------------------------------------------------------------------
@elem dot
zone: x-height
path: p1 p2 p3 p4
p1 = [6,7]
p2 = C([7,7] [7,8])
p3 = C([7,9] [6,9])
p4 = C([5,9] [5,8])
close: true
width: 1
anchors: attach=[6,8]
@end

# dot.mid - Mid-height dot (as in interpunct)
@elem dot.mid
zone: x-height
path: p1 p2 p3 p4
p1 = [6,5]
p2 = C([7,5] [7,6])
p3 = C([7,7] [6,7])
p4 = C([5,7] [5,6])
close: true
width: 1
anchors: attach=[6,6]
@end

# dot.high - High dot (as in colon top)
@elem dot.high
zone: x-height
path: p1 p2 p3 p4
p1 = [6,4]
p2 = C([7,4] [7,5])
p3 = C([7,6] [6,6])
p4 = C([5,6] [5,5])
close: true
width: 1
anchors: attach=[6,5]
@end

# -----------------------------------------------------------------------------
# caron.alt - Vertical stroke hacek variant (as in d-caron, t-caron, L-caron)
# -----------------------------------------------------------------------------
@elem caron.alt
zone: x-height
path: p1 p2
p1 = [8,3]
p2 = [9,5]
close: false
width: 1
anchors: attach=[8,4]
@end

# caron.alt.l - Left-positioned caron.alt
@elem caron.alt.l
zone: x-height
path: p1 p2
p1 = [4,3]
p2 = [3,5]
close: false
width: 1
anchors: attach=[4,4]
@end

# -----------------------------------------------------------------------------
# comma.shape - Comma-shaped mark (as in Cyrillic palatal marks)
# -----------------------------------------------------------------------------
@elem comma.shape
zone: x-height
path: p1 p2 p3
p1 = [6,7]
p2 = C([7,8] [6,9])
p3 = [5,9]
close: false
width: 1
anchors: attach=[6,7]
@end

# comma.shape.above - Above comma shape (as in comma above diacritic)
@elem comma.shape.above
zone: diacritic-above
path: p1 p2 p3
p1 = [6,1]
p2 = C([7,2] [6,3])
p3 = [5,3]
close: false
width: 1
anchors: attach=[6,2]
@end

# comma.shape.below - Below comma shape
@elem comma.shape.below
zone: diacritic-below
path: p1 p2 p3
p1 = [6,9]
p2 = C([7,10] [6,11])
p3 = [5,11]
close: false
width: 1
anchors: attach=[6,9]
@end

# =============================================================================
# VARIANT ELEMENTS USING from_expr
# =============================================================================

# Shifted stem variants
@elem stem.shifted.l
build: from_expr
sh(stem, dx=-4, dy=0)
@end

@elem stem.shifted.r
build: from_expr
sh(stem, dx=4, dy=0)
@end

# Scaled bowl variants
@elem bowl.small
build: from_expr
sc(bowl, sx=9, sy=9)
@end

@elem bowl.large
build: from_expr
sc(bowl, sx=14, sy=14)
@end

# Mirrored/transformed variants
@elem bowl.l.cap
build: from_expr
sc(bowl.l, sx=12, sy=16)
@end

@elem bowl.r.cap
build: from_expr
sc(bowl.r, sx=12, sy=16)
@end

# =============================================================================
# END OF STANDARD ELEMENT LIBRARY
# =============================================================================
