@lsdl 1.0

# Ligatures test: LIG operator with merge: strategies

# ============================================================
# Element Definitions
# ============================================================

@elem stem
zone: x-height
path: p1 p2
p1 = [6,4]
p2 = [6,8]
width: 1
anchors: top=[6,4] base=[6,8] mid=[6,6]
  mark-above=[6,3] mark-below=[6,9]
@end

@elem ascender
zone: ascender
path: p1 p2
p1 = [6,1]
p2 = [6,8]
width: 1
anchors: top=[6,1] base=[6,8] mid=[6,4]
  mark-above=[6,0] mark-below=[6,9]
@end

@elem hook.top
zone: ascender
path: p1 p2 p3
p1 = [8,1]
p2 = C([4,1] [4,4])
p3 = [4,8]
width: 1
anchors: attach=[8,1] base=[4,8]
@end

@elem crossbar
zone: x-height
path: p1 p2
p1 = [2,6]
p2 = [10,6]
width: 1
anchors: left=[2,6] right=[10,6] mid=[6,6]
@end

@elem tittle
zone: x-height
path: p1
p1 = [6,3]
width: 1
anchors: attach=[6,4]
@end

@elem bowl.full
zone: x-height
path: p1 p2 p3 p4
p1 = [6,4]
p2 = C([12,4] [12,8])
p3 = [6,8]
p4 = C([0,8] [0,4])
close: true
width: 1
anchors: attach=[6,6] mark-above=[6,3] mark-below=[6,9]
@end

@elem bowl.l
zone: x-height
path: p1 p2 p3
p1 = [6,4]
p2 = C([0,4] [0,8])
p3 = [6,8]
close: true
width: 1
anchors: attach=[6,6] mark-above=[4,3] mark-below=[4,9]
@end

@elem apex
zone: cap
path: p1 p2 p3
p1 = [2,8]
p2 = [6,0]
p3 = [10,8]
width: 1
anchors: top=[6,0] left=[2,8] right=[10,8]
@end

@elem diagonal.l
zone: cap
path: p1 p2
p1 = [2,0]
p2 = [6,8]
width: 1
anchors: top=[2,0] base=[6,8]
@end

@elem diagonal.r
zone: cap
path: p1 p2
p1 = [10,0]
p2 = [6,8]
width: 1
anchors: top=[10,0] base=[6,8]
@end

@elem stem.l
zone: cap
path: p1 p2
p1 = [2,0]
p2 = [2,8]
width: 1
anchors: top=[2,0] base=[2,8] mid=[2,4]
@end

@elem arm
zone: x-height
path: p1 p2
p1 = [2,4]
p2 = [8,4]
width: 1
anchors: attach=[2,4]
@end

@elem arm.mid
zone: x-height
path: p1 p2
p1 = [2,5]
p2 = [8,5]
width: 1
anchors: attach=[2,5]
@end

@elem bar.bot
zone: x-height
path: p1 p2
p1 = [2,8]
p2 = [10,8]
width: 1
anchors: left=[2,8] right=[10,8] mid=[6,8]
@end

@elem arc.top
zone: x-height
path: p1 p2 p3
p1 = [10,6]
p2 = C([10,4] [6,4])
p3 = [2,6]
width: 1
anchors: left=[2,6] right=[10,6] top=[6,4]
@end

@elem arc.bot
zone: x-height
path: p1 p2 p3
p1 = [2,6]
p2 = C([2,8] [6,8])
p3 = [10,8]
width: 1
anchors: left=[2,6] right=[10,8] base=[6,8]
@end

# ============================================================
# Base Characters for Ligature Composition
# ============================================================

A  LATIN-CAPITAL-A        = APEX(diagonal.l, diagonal.r, crossbar) script:Latn
E  LATIN-CAPITAL-E        = FRAME(stem.l, arm, arm.mid, bar.bot) script:Latn
O  LATIN-CAPITAL-O        = bowl.full script:Latn

a  LATIN-SMALL-A          = LR(bowl.l, stem, 8/4) script:Latn
e  LATIN-SMALL-E          = FRAME(arc.top, crossbar, arc.bot) script:Latn
f  LATIN-SMALL-F          = FRAME(hook.top, crossbar) script:Latn
i  LATIN-SMALL-I          = STACK(tittle, stem) script:Latn
l  LATIN-SMALL-L          = ascender script:Latn
o  LATIN-SMALL-O          = bowl.full script:Latn

# ============================================================
# Case Mappings for Ligatures
# ============================================================

@case Æ æ
@case Œ œ

# ============================================================
# Standard Latin Ligatures with merge: strategies
# ============================================================

# fi ligature - f hook absorbs the i tittle
ﬁ  LATIN-SMALL-LIGATURE-FI = LIG(f, i, merge:hook-tittle) cp:U+FB01 script:Latn

# fl ligature - f hook merges into l ascender
ﬂ  LATIN-SMALL-LIGATURE-FL = LIG(f, l, merge:hook-ascender) cp:U+FB02 script:Latn

# ff ligature - two f hooks merged
ﬀ  LATIN-SMALL-LIGATURE-FF = LIG(f, f, merge:hook-hook) cp:U+FB00 script:Latn

# ffi ligature - three-part merge
ﬃ  LATIN-SMALL-LIGATURE-FFI = LIG(ﬀ, i, merge:hook-tittle) cp:U+FB03 script:Latn

# ffl ligature - three-part merge
ﬄ  LATIN-SMALL-LIGATURE-FFL = LIG(ﬀ, l, merge:hook-ascender) cp:U+FB04 script:Latn

# ============================================================
# Capital Ligatures
# ============================================================

# AE ligature - shared stem between A and E
Æ  LATIN-CAPITAL-AE = LIG(A, E, merge:stem-shared) cp:U+00C6 script:Latn ortho:Dan,Nor

# ae ligature (lowercase)
æ  LATIN-SMALL-AE = LIG(a, e, merge:stem-shared) cp:U+00E6 script:Latn ortho:Dan,Nor

# OE ligature - bowl merges into stem
Œ  LATIN-CAPITAL-OE = LIG(O, E, merge:bowl-stem) cp:U+0152 script:Latn ortho:Fra

# oe ligature (lowercase)
œ  LATIN-SMALL-OE = LIG(o, e, merge:bowl-stem) cp:U+0153 script:Latn ortho:Fra

# ============================================================
# LIG without merge: (defaults to horizontal adjacency)
# ============================================================

# This demonstrates LIG without a merge strategy
# Behaves like LR(f, f) - simple horizontal placement
ff  LATIN-SMALL-FF-SIMPLE = LIG(f, f) script:Latn
